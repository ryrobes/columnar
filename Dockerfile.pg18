FROM postgres:18-bookworm AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc make libssl-dev autoconf pkg-config \
    postgresql-server-dev-18 \
    libcurl4-gnutls-dev liblz4-dev libzstd-dev \
    git ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Build columnar extension
COPY columnar /columnar
WORKDIR /columnar
RUN ./configure && make clean && make && make install

# Build pgvector
WORKDIR /tmp
RUN git clone --branch v0.8.2 https://github.com/pgvector/pgvector.git && \
    cd pgvector && \
    make OPTFLAGS="-march=x86-64-v3" && make install && \
    cd / && rm -rf /tmp/pgvector

# --- Runtime image ---
FROM postgres:18-bookworm

# Copy columnar extension
COPY --from=builder /usr/share/postgresql/18/extension/columnar* /usr/share/postgresql/18/extension/
COPY --from=builder /usr/lib/postgresql/18/lib/columnar.so /usr/lib/postgresql/18/lib/columnar.so
COPY --from=builder /usr/lib/postgresql/18/lib/bitcode/columnar* /usr/lib/postgresql/18/lib/bitcode/

# Copy pgvector extension
COPY --from=builder /usr/share/postgresql/18/extension/vector* /usr/share/postgresql/18/extension/
COPY --from=builder /usr/lib/postgresql/18/lib/vector.so /usr/lib/postgresql/18/lib/vector.so
COPY --from=builder /usr/lib/postgresql/18/lib/bitcode/vector* /usr/lib/postgresql/18/lib/bitcode/

# Init scripts: create extensions on first startup
COPY files/postgres/docker-entrypoint-initdb.d /docker-entrypoint-initdb.d/
